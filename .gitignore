# Dependencies
node_modules/

# Build outputs
dist/
.vite/
.wrangler/

# Environment / secrets
.env
.env.local
.env.*.local
.dev.vars

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.cursor/
*.log
*.swp
*.swo

# Private decks — local-only, never committed.
# Per AGENTS.md, customer-specific or under-NDA decks live here. They run via
# `npm run dev` on the author's machine but never reach the deployed app.
src/decks/private/*
!src/decks/private/.gitkeep

# Per-machine agent artefacts
skill-observations/
RESUME_PROMPT.md
.aider*

# Test artefacts
test-results/
coverage/

# Thumbnails — build artefacts produced by `npm run thumbnails`. Regenerated
# before deploy; not committed. Production gracefully falls back to text
# tiles when these are absent.
public/thumbnails/

# OS
Thumbs.db
ehthumbs.db

# Session-resume prompt — local-only, not part of the repo's public docs.
# Regenerate at the end of each session for the next agent to pick up.
RESUME.md
